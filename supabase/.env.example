# ============================================
# SUPABASE CONFIGURATION (ALL ENVIRONMENTS)
# BookYourService - Enterprise Grade
# ============================================

# ----------------------------------------
# Supabase Project Configuration
# ----------------------------------------

# Supabase Project URL
# Get from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key (SECRET - NEVER EXPOSE)
# Use this for server-side operations (Edge Functions, backend)
# Get from Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Anon Key (Public)
# Use this for client-side operations (Frontend)
# Get from Supabase Dashboard → Settings → API → anon (public)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------
# PAYMENT GATEWAY CONFIGURATION
# ----------------------------------------

# Razorpay Configuration
# Get from Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here

# Stripe Configuration
# Get from Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Webhook Secrets (CRITICAL - Never expose)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ----------------------------------------
# SECURITY CONFIGURATION
# ----------------------------------------

# Environment (development | staging | production)
NODE_ENV=development

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# Backend/Edge Function URL (for webhooks)
EDGE_FUNCTIONS_URL=https://your-project-id.supabase.co/functions/v1

# ----------------------------------------
# OPTIONAL: THIRD-PARTY INTEGRATIONS
# ----------------------------------------

# Twilio (SMS/WhatsApp notifications)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# SendGrid (Email notifications)
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Firebase Cloud Messaging (Push notifications)
FCM_SERVER_KEY=your_fcm_server_key

# ----------------------------------------
# MONITORING & LOGGING
# ----------------------------------------

# Sentry (Error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# Datadog (APM monitoring)
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key

# ----------------------------------------
# FEATURE FLAGS
# ----------------------------------------

# Enable/disable features
PAYMENTS_ENABLED=true
SMS_NOTIFICATIONS_ENABLED=false
EMAIL_NOTIFICATIONS_ENABLED=true
PUSH_NOTIFICATIONS_ENABLED=false
PROVIDER_APPROVAL_FLOW=true

# ----------------------------------------
# DEVELOPMENT NOTES
# ----------------------------------------

# 1. NEVER commit this file with real values
# 2. Always use .env.local for local development
# 3. Use environment-specific .env files (.env.staging, .env.production)
# 4. Rotate secrets regularly (every 90 days recommended)
# 5. Use Supabase Edge Functions for all server-side operations
# 6. Never use service_role key in frontend
# 7. Never expose webhook secrets
# 8. Always validate payment signatures in webhooks
