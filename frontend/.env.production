# Frontend Production Environment Variables
# ⚠️ IMPORTANT: These values are baked into the build at compile time
# After modifying, you MUST rebuild the frontend

# Backend API Base URL
# Must include /api suffix as backend runs on /api base path
VITE_API_BASE_URL=https://bookyourservice-api-48728079466.europe-west1.run.app/api

# Application Environment
VITE_APP_ENV=production
VITE_APP_NAME=BookYourService

