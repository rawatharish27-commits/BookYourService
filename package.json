{
  "name": "bookyourservice",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Enterprise-grade service booking platform with AI, real-time features, and advanced integrations",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "analyze": "vite build --mode analyze",
    "pwa": "vite build && workbox generateSW",
    "docker:build": "docker build -t bookyourservice .",
    "docker:run": "docker run -p 3000:3000 bookyourservice",
    "backend:dev": "cd backend && npm run dev",
    "backend:build": "cd backend && npm run build",
    "start": "concurrently \"npm run dev\" \"npm run backend:dev\"",
    "e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
